# Dockerfile for Config Daemon
# Config Daemon watches AIAgent CRDs and syncs AgentConfig to hostPath
FROM golang:1.23-alpine AS builder

WORKDIR /workspace

# Copy go.mod and go.sum
COPY go.mod go.sum ./
RUN go mod download

# Copy source code
COPY api/ api/
COPY pkg/ pkg/
COPY cmd/ cmd/

# Build config-daemon binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -a -o config-daemon ./cmd/config-daemon

# Final stage
FROM alpine:3.18

WORKDIR /
RUN apk --no-cache add ca-certificates tzdata

COPY --from=builder /workspace/config-daemon .

# Create non-root user
RUN adduser -D -u 1000 config-daemon
USER 1000

ENTRYPOINT ["/config-daemon"]