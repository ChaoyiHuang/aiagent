# Dockerfile for AI Agent Controller Manager
FROM golang:1.25-alpine AS builder

WORKDIR /workspace

# Copy adk-go module first (for local replace directive)
COPY adk-go/ /adk-go/

# Copy aiagent module
COPY aiagent/go.mod aiagent/go.sum ./

# Download dependencies
RUN go mod download

# Copy source code
COPY aiagent/api/ api/
COPY aiagent/pkg/ pkg/
COPY aiagent/cmd/ cmd/

# Build manager binary
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -a -o manager ./cmd/manager

# Final stage
FROM alpine:3.18

WORKDIR /
RUN apk --no-cache add ca-certificates tzdata

COPY --from=builder /workspace/manager .

# Create non-root user
RUN adduser -D -u 1000 manager
USER 1000

ENTRYPOINT ["/manager"]